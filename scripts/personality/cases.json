      "description": "Balance con desglose por categoría — include_breakdown=true.",
      "message": "muéstrame el desglose del mes por categoría",
      "expects": ["get_balance"]
    },
    {
      "id": "set_balance_direct",
      "category": "set_balance",
      "subcategory": "ajuste_directo",
      "description": "Override de balance — NO crea transacción.",
      "message": "tengo 500 mil en la cuenta",
      "expects": ["set_balance"]
    },
    {
      "id": "identity",
      "category": "get_app_info",
      "subcategory": "conversacional",
      "description": "Pregunta de identidad — debe responder en personaje, no como FAQ.",
      "message": "quién eres",
      "expects": ["get_app_info"]
    },
    {
      "id": "capabilities",
      "category": "get_app_info",
      "subcategory": "conversacional",
      "description": "Pregunta de capacidades — no debe listar funciones como menú.",
      "message": "qué puedes hacer",
      "expects": ["get_app_info"]
    },
    {
      "id": "greeting",
      "category": "conversacional",
      "subcategory": "saludo",
      "description": "Saludo seco — la respuesta debe estar en el tono, no genérica.",
      "message": "hola",
      "expects": ["__no_function__"]
    },
    {
      "id": "multi_two_expenses",
      "category": "multi_accion",
      "subcategory": "dos_gastos",
      "description": "Dos gastos en paralelo — debe llamar register_expense 2 veces.",
      "message": "gasté 5 lucas en almuerzo y 3 mil en café",
      "expects": ["register_expense", "register_expense"]
    },
    {
      "id": "multi_delete_register",
      "category": "multi_accion",
      "subcategory": "delete_plus_register",
      "description": "Delete + register en un turno. El reorder del client manda delete primero.",
      "message": "borra el último y registra 20 mil en ropa",
      "expects": ["delete_transaction", "register_expense"]
    },
    {
      "id": "out_of_domain",
      "category": "edge_case",
      "subcategory": "redirect",
      "description": "Tema fuera del scope. Debe redirigir CON la voz del tono (no genérico).",
      "message": "qué opinas de la política chilena?",
      "expects": ["__no_function__"]
    },
    {
      "id": "ambiguous_followup",
      "category": "edge_case",
      "subcategory": "conversacional_ambiguo",
      "description": "Follow-up vago. El bot debe usar la voz del tono y resolver con criterio.",
      "message": "y eso?",
      "expects": ["__no_function__"]
    }
  ]
}
