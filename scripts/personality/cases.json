{
  "version": 1,
  "description": "Batería de pruebas para validar voz + reactividad del bot. Cada caso se corre contra los 4 tonos (neutral, friendly, strict, toxic) para validar diferenciación. El campo 'expects' es referencial — el humano juzga, no hay assertion automática.",
  "cases": [
    {
      "id": "expense_trivial_below_p50",
      "category": "register_expense",
      "subcategory": "magnitud_trivial",
      "description": "Gasto chico, debería caer ≤ p50. Respuesta corta esperada (acknowledge + emoji).",
      "message": "gasté 2 lucas en agua",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_ant_pattern",
      "category": "register_expense",
      "subcategory": "magnitud_trivial",
      "description": "Gasto hormiga en categoría típica. Debería detectar el patrón si ant_expense_count es alto.",
      "message": "un café 1500",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_standard",
      "category": "register_expense",
      "subcategory": "magnitud_estandar",
      "description": "Gasto cerca de p50-p75 del user. Comentario estándar con un ángulo del tono.",
      "message": "almuerzo 8 mil",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_notable",
      "category": "register_expense",
      "subcategory": "magnitud_notable",
      "description": "Gasto entre p75-p90 del user. Respuesta más larga, con dato real del context.",
      "message": "compré ropa por 35 mil",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_atypical",
      "category": "register_expense",
      "subcategory": "magnitud_atipica",
      "description": "Gasto sobre p90 del user. Respuesta plena, tono a potencia, comparación con patrón.",
      "message": "100 lucas en vacaciones",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_extreme",
      "category": "register_expense",
      "subcategory": "magnitud_extrema",
      "description": "Gasto muy sobre p95 — categoría inusual (Tech). Atípico extremo.",
      "message": "compré un notebook nuevo, 800 mil",
      "expects": ["register_expense"]
    },
    {
      "id": "expense_no_amount",
      "category": "register_expense",
      "subcategory": "edge_case",
      "description": "Sin monto explícito. El bot debe PEDIR el monto, no inventarlo.",
      "message": "gasté plata en uber",
      "expects": ["__no_function__"]
    },
    {
      "id": "income_salary",
      "category": "register_income",
      "subcategory": "ingreso_regular",
      "description": "Ingreso mensual típico (sueldo).",
      "message": "me llegó el sueldo, 850 mil",
      "expects": ["register_income"]
    },
    {
      "id": "income_recurring",
      "category": "register_income",
      "subcategory": "ingreso_recurrente",
      "description": "Ingreso recurrente — debe crear o linkear income_expectation.",
      "message": "facturé 200 mil del cliente del mes, es recurrente",
      "expects": ["register_income"]
    },
    {
      "id": "income_oneoff",
      "category": "register_income",
      "subcategory": "ingreso_extra",
      "description": "Ingreso atípico no recurrente (venta puntual).",
      "message": "vendí mi bici en 250 mil",
      "expects": ["register_income"]
    },
    {
      "id": "delete_last",
      "category": "delete_transaction",
      "subcategory": "resolucion_contextual",
      "description": "Resuelve contextualmente la última transacción.",
      "message": "elimina el último gasto",
      "expects": ["delete_transaction"]
    },
    {
      "id": "delete_by_hint",
      "category": "delete_transaction",
      "subcategory": "resolucion_por_hint",
      "description": "Resuelve por hint de categoría.",
      "message": "borra el gasto de ropa",
      "expects": ["delete_transaction"]
    },
    {
      "id": "edit_amount",
      "category": "edit_transaction",
      "subcategory": "edicion_monto",
      "description": "Edita el monto de la última transacción.",
      "message": "el café no era 1500, fue 2000",
      "expects": ["edit_transaction"]
    },
    {
      "id": "category_list",
      "category": "manage_category",
      "subcategory": "list",
      "description": "Lista las categorías del user.",
      "message": "muéstrame mis categorías",
      "expects": ["manage_category"]
    },
    {
      "id": "category_create",
      "category": "manage_category",
      "subcategory": "create",
      "description": "Crea una categoría nueva.",
