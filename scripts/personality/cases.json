      "description": "Lista de gastos de la semana.",
      "message": "muéstrame mis gastos de la semana",
      "expects": ["query_transactions"]
    },
    {
      "id": "query_sum_category",
      "category": "query_transactions",
      "subcategory": "sum_filtrado",
      "description": "Suma con filtro por categoría.",
      "message": "cuánto gasté en transporte este mes",
      "expects": ["query_transactions"]
    },
    {
      "id": "query_count",
      "category": "query_transactions",
      "subcategory": "count",
      "description": "Conteo de transacciones del mes.",
      "message": "cuántos gastos llevo este mes",
      "expects": ["query_transactions"]
    },
    {
      "id": "balance_simple",
      "category": "get_balance",
      "subcategory": "balance_basico",
      "description": "Consulta de balance directo.",
      "message": "cuánto tengo",
      "expects": ["get_balance"]
    },
    {
      "id": "balance_breakdown",
      "category": "get_balance",
